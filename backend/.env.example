# PostgreSQL connection string
DATABASE_URL="postgresql://pos_user:pos_password@localhost:5432/pos_system"

# Generate a secure random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-secure-random-secret"

PORT=5000

# Comma-separated list of allowed CORS origins
CLIENT_URL="http://localhost:3000,http://localhost:5173"

# Optional: SMTP for email OTP delivery
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-app-password"
# SMTP_SECURE="false"
# SMTP_FROM="POS System <noreply@example.com>"

# Optional: Twilio for SMS OTP delivery
# SMS_PROVIDER="twilio"
# TWILIO_ACCOUNT_SID="your-account-sid"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_PHONE="+1234567890"
